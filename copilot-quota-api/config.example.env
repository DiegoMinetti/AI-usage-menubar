# Example environment variables
GITHUB_TOKEN=your_github_token_here
PORT=3000
POLL_INTERVAL_MS=60000
MAX_RETRY_ATTEMPTS=5
# Optional: OAuth client ID to use Device Flow for login (no client secret needed)
# Set this to run copilot-quota-api/device_oauth.js to obtain and save a token in Keychain.
COPILOT_OAUTH_CLIENT_ID=
COPILOT_OAUTH_SCOPE=read:user
